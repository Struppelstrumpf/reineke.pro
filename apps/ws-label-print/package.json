{
  "name": "ws-label-print",
  "version": "1.5.0",
  "description": "Weißer Schäfer — Etikettendruck für Windows",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable --x64",
    "build:win": "electron-builder --win portable --x64",
    "build": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "pro.reineke.ws-label-print",
    "productName": "WS Etikettendruck",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ws-etikettendruck.${ext}",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "ws-etikettendruck.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8"
  }
}
